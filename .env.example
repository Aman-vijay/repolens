# =====================================================================
# RepoLens — environment contract
# Copy to .env for local dev. Never commit .env.
# Each var annotated with: who consumes it, and which milestone uses it.
# Per-environment supply story in docs/adr/0006-secrets-and-environment-management.md
# =====================================================================

# --- Neon (Postgres + pgvector) — consumed by packages/db ---
# Dev: your dev Neon project connection string (single shared dev project; see ADR 0006).
# Prod: Render env var pointing at prod Neon project.
# Used from M1 onward.
DATABASE_URL=postgresql+psycopg://user:password@ep-xxxx.neon.tech/repolens?sslmode=require

# --- Upstash (Redis) — consumed by apps/api (producer) + workers (consumer) ---
# MUST be the Redis-protocol URL (rediss://), NOT the REST endpoint.
# arq compatibility MUST be spiked in M3 before building producer/consumer logic.
# See ADR 0004 (managed infra) and ADR 0005 (arq maintenance-mode).
REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# --- Clerk (auth) — M1 ---
# Frontend publishable key (safe for browser bundle) — set on Vercel.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# Backend secret key — set on Render only, never on Vercel.
CLERK_SECRET_KEY=sk_test_xxxxx
# Webhook signing secret for Clerk -> API user-sync webhook — set on Render.
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# --- Frontend -> API URL ---
# Local dev: localhost:8000. Prod: Render API URL, set on Vercel.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- OpenAI (AI summary + chat) — M4/M5 ---
# Backend/worker only — set on Render, never on Vercel.
OPENAI_API_KEY=sk-xxxxx

# --- Cloudflare R2 (repository storage) — consumed in M2, listed now for contract completeness ---
# Backend/worker only — set on Render.
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=repolens-repos
R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
