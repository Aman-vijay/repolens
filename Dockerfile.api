FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY uv.lock pyproject.toml ./
COPY apps/api/pyproject.toml apps/api/
COPY workers/pyproject.toml workers/
COPY packages/db/pyproject.toml packages/db/
COPY packages/prompts/pyproject.toml packages/prompts/
RUN pip install uv && uv python install 3.12 && uv sync --frozen --no-install-project --all-packages --python 3.12

COPY . .

WORKDIR /app/apps/api

EXPOSE 8000

ENV PYTHONUNBUFFERED=1
ENV NODE_ENV=${NODE_ENV:-production}
ENV DATABASE_URL=${DATABASE_URL}
ENV REDIS_URL=${REDIS_URL}
ENV CLERK_SECRET_KEY=${CLERK_SECRET_KEY}
ENV CLERK_WEBHOOK_SECRET=${CLERK_WEBHOOK_SECRET}
ENV FRONTEND_URL=${FRONTEND_URL:-https://your-frontend.vercel.app}
ENV OPENAI_API_KEY=${OPENAI_API_KEY}
ENV SUPERADMIN_CLERK_USER_ID=${SUPERADMIN_CLERK_USER_ID}

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
