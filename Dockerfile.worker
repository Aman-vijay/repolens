FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY uv.lock pyproject.toml ./
RUN pip install uv && uv sync --frozen --no-install-project --all-packages

COPY . .

ENV PYTHONUNBUFFERED=1
ENV DATABASE_URL=${DATABASE_URL}
ENV REDIS_URL=${REDIS_URL}
ENV CLERK_SECRET_KEY=${CLERK_SECRET_KEY}
ENV CLERK_WEBHOOK_SECRET=${CLERK_WEBHOOK_SECRET}
ENV FRONTEND_URL=http://localhost:3000
ENV OPENAI_API_KEY=${OPENAI_API_KEY}
ENV SUPERADMIN_CLERK_USER_ID=${SUPERADMIN_CLERK_USER_ID}

CMD ["arq", "workers.worker.WorkerSettings"]
